{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowJs": true,
    "resolveJsonModule": true,
    "types": ["cypress", "node"],
    "strict": false
  },
  "include": ["cypress/**/*.ts", "cypress.config.js"]
}
